	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.duovelop.memo</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.duovelop.memo</string>
			</array>
		</dict>
	</array>
